{
  "$schema": "vscode://schemas/color-theme",
  "name": "Claret Light",
  "type": "light",
  "colors": {
    "editor.background": "#F4EBDF",
    "editor.foreground": "#2A1F1A",
    "editor.lineHighlightBackground": "#DAD0C0",
    "editor.selectionBackground": "#DAD0C099",
    "editor.wordHighlightBackground": "#DAD0C066",
    "editor.findMatchBackground": "#96600A44",
    "editor.findMatchHighlightBackground": "#96600A22",
    "editorCursor.foreground": "#8B2252",
    "editorLineNumber.foreground": "#928578",
    "editorLineNumber.activeForeground": "#96600A",
    "editorIndentGuide.background1": "#C8BDA8",
    "editorIndentGuide.activeBackground1": "#928578",
    "editorBracketMatch.background": "#DAD0C0",
    "editorBracketMatch.border": "#8B2252",
    "editorGutter.addedBackground": "#456B28",
    "editorGutter.modifiedBackground": "#96600A",
    "editorGutter.deletedBackground": "#A03025",
    "editorError.foreground": "#A03025",
    "editorWarning.foreground": "#96600A",
    "editorInfo.foreground": "#3A4E6E",
    "sideBar.background": "#E9DECE",
    "sideBar.foreground": "#4D4035",
    "sideBar.border": "#C8BDA8",
    "sideBarTitle.foreground": "#2A1F1A",
    "sideBarSectionHeader.background": "#DAD0C0",
    "sideBarSectionHeader.foreground": "#2A1F1A",
    "activityBar.background": "#E9DECE",
    "activityBar.foreground": "#2A1F1A",
    "activityBar.inactiveForeground": "#928578",
    "activityBarBadge.background": "#8B2252",
    "activityBarBadge.foreground": "#F4EBDF",
    "titleBar.activeBackground": "#E9DECE",
    "titleBar.activeForeground": "#4D4035",
    "titleBar.inactiveBackground": "#E9DECE",
    "titleBar.inactiveForeground": "#928578",
    "statusBar.background": "#DAD0C0",
    "statusBar.foreground": "#4D4035",
    "statusBar.debuggingBackground": "#A03025",
    "statusBar.debuggingForeground": "#F4EBDF",
    "statusBar.noFolderBackground": "#DAD0C0",
    "tab.activeBackground": "#F4EBDF",
    "tab.activeForeground": "#2A1F1A",
    "tab.inactiveBackground": "#E9DECE",
    "tab.inactiveForeground": "#6B5F55",
    "tab.border": "#C8BDA8",
    "tab.activeBorderTop": "#8B2252",
    "editorGroupHeader.tabsBackground": "#E9DECE",
    "panel.background": "#E9DECE",
    "panel.border": "#C8BDA8",
    "panelTitle.activeForeground": "#2A1F1A",
    "panelTitle.activeBorder": "#8B2252",
    "panelTitle.inactiveForeground": "#6B5F55",
    "input.background": "#F4EBDF",
    "input.foreground": "#2A1F1A",
    "input.border": "#C8BDA8",
    "input.placeholderForeground": "#928578",
    "inputOption.activeBorder": "#8B2252",
    "dropdown.background": "#F4EBDF",
    "dropdown.foreground": "#2A1F1A",
    "dropdown.border": "#C8BDA8",
    "button.background": "#8B2252",
    "button.foreground": "#F4EBDF",
    "button.hoverBackground": "#722F37",
    "badge.background": "#8B2252",
    "badge.foreground": "#F4EBDF",
    "list.activeSelectionBackground": "#DAD0C0",
    "list.activeSelectionForeground": "#2A1F1A",
    "list.hoverBackground": "#DAD0C088",
    "list.focusBackground": "#DAD0C0",
    "list.highlightForeground": "#8B2252",
    "scrollbar.shadow": "#C8BDA844",
    "scrollbarSlider.background": "#C8BDA844",
    "scrollbarSlider.hoverBackground": "#C8BDA888",
    "scrollbarSlider.activeBackground": "#C8BDA8AA",
    "focusBorder": "#8B225266",
    "foreground": "#2A1F1A",
    "widget.shadow": "#C8BDA844",
    "selection.background": "#DAD0C099",
    "gitDecoration.addedResourceForeground": "#456B28",
    "gitDecoration.modifiedResourceForeground": "#96600A",
    "gitDecoration.deletedResourceForeground": "#A03025",
    "gitDecoration.untrackedResourceForeground": "#3A4E6E",
    "gitDecoration.conflictingResourceForeground": "#8B2252",
    "terminal.ansiBlack": "#2A1F1A",
    "terminal.ansiRed": "#A03025",
    "terminal.ansiGreen": "#456B28",
    "terminal.ansiYellow": "#96600A",
    "terminal.ansiBlue": "#3A4E6E",
    "terminal.ansiMagenta": "#8B2252",
    "terminal.ansiCyan": "#3A4E6E",
    "terminal.ansiWhite": "#F4EBDF",
    "terminal.ansiBrightBlack": "#928578",
    "terminal.ansiBrightRed": "#8A2820",
    "terminal.ansiBrightGreen": "#3A5A20",
    "terminal.ansiBrightYellow": "#A87010",
    "terminal.ansiBrightBlue": "#2E3E5A",
    "terminal.ansiBrightMagenta": "#722F37",
    "terminal.ansiBrightCyan": "#2E3E5A",
    "terminal.ansiBrightWhite": "#4D4035",
    "terminal.foreground": "#2A1F1A",
    "terminal.background": "#F4EBDF",
    "breadcrumb.foreground": "#6B5F55",
    "breadcrumb.focusForeground": "#2A1F1A",
    "breadcrumb.activeSelectionForeground": "#8B2252",
    "editorWidget.background": "#E9DECE",
    "editorWidget.border": "#C8BDA8",
    "editorSuggestWidget.selectedBackground": "#DAD0C0",
    "peekView.border": "#8B2252",
    "peekViewEditor.background": "#E9DECE",
    "peekViewResult.background": "#E9DECE",
    "peekViewTitle.background": "#DAD0C0",
    "peekViewTitleLabel.foreground": "#2A1F1A",
    "peekViewTitleDescription.foreground": "#6B5F55",
    "minimap.findMatchHighlight": "#96600A44",
    "minimap.selectionHighlight": "#DAD0C099",
    "minimapGutter.addedBackground": "#456B28",
    "minimapGutter.modifiedBackground": "#96600A",
    "minimapGutter.deletedBackground": "#A03025",
    "editorBracketHighlight.foreground1": "#8B2252",
    "editorBracketHighlight.foreground2": "#96600A",
    "editorBracketHighlight.foreground3": "#3A4E6E",
    "editorBracketHighlight.foreground4": "#456B28",
    "editorBracketHighlight.foreground5": "#4D4035",
    "editorBracketHighlight.foreground6": "#6B5F55",
    "editorBracketHighlight.unexpectedBracket.foreground": "#A03025"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": "comment, punctuation.definition.comment",
      "settings": { "foreground": "#928578", "fontStyle": "italic" }
    },
    {
      "name": "Keywords",
      "scope": "keyword, storage.type, storage.modifier",
      "settings": { "foreground": "#8B2252" }
    },
    {
      "name": "Control keywords italic",
      "scope": "keyword.control",
      "settings": { "foreground": "#8B2252", "fontStyle": "italic" }
    },
    {
      "name": "Operators",
      "scope": "keyword.operator",
      "settings": { "foreground": "#4D4035" }
    },
    {
      "name": "Functions",
      "scope": "entity.name.function, support.function",
      "settings": { "foreground": "#96600A" }
    },
    {
      "name": "Strings",
      "scope": "string, string.quoted",
      "settings": { "foreground": "#456B28" }
    },
    {
      "name": "Numbers",
      "scope": "constant.numeric",
      "settings": { "foreground": "#96600A" }
    },
    {
      "name": "Booleans",
      "scope": "constant.language.boolean, constant.language",
      "settings": { "foreground": "#96600A" }
    },
    {
      "name": "Types",
      "scope": "entity.name.type, support.type, entity.name.class, entity.name.interface",
      "settings": { "foreground": "#3A4E6E" }
    },
    {
      "name": "Constants",
      "scope": "constant, variable.other.constant",
      "settings": { "foreground": "#3A4E6E" }
    },
    {
      "name": "Variables",
      "scope": "variable, variable.other.readwrite",
      "settings": { "foreground": "#2A1F1A" }
    },
    {
      "name": "Parameters",
      "scope": "variable.parameter",
      "settings": { "foreground": "#4D4035" }
    },
    {
      "name": "Properties",
      "scope": "variable.other.property, variable.other.object.property",
      "settings": { "foreground": "#4D4035" }
    },
    {
      "name": "Preprocessor",
      "scope": "meta.preprocessor, keyword.control.directive, keyword.control.import",
      "settings": { "foreground": "#96600A" }
    },
    {
      "name": "Invalid",
      "scope": "invalid, invalid.illegal",
      "settings": { "foreground": "#A03025" }
    },
    {
      "name": "Labels",
      "scope": "entity.name.label",
      "settings": { "foreground": "#8B2252" }
    },
    {
      "name": "Tags",
      "scope": "entity.name.tag",
      "settings": { "foreground": "#8B2252" }
    },
    {
      "name": "Attributes",
      "scope": "entity.other.attribute-name",
      "settings": { "foreground": "#96600A" }
    },
    {
      "name": "CSS properties",
      "scope": "support.type.property-name",
      "settings": { "foreground": "#3A4E6E" }
    },
    {
      "name": "Punctuation",
      "scope": "punctuation, punctuation.definition, punctuation.separator, punctuation.terminator",
      "settings": { "foreground": "#4D4035" }
    },
    {
      "name": "String punctuation inherits string",
      "scope": "punctuation.definition.string",
      "settings": { "foreground": "#456B28" }
    },
    {
      "name": "Escape characters",
      "scope": "constant.character.escape",
      "settings": { "foreground": "#96600A" }
    },
    {
      "name": "Markdown headings",
      "scope": "markup.heading, entity.name.section",
      "settings": { "foreground": "#8B2252", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": "markup.bold",
      "settings": { "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": "markup.italic",
      "settings": { "fontStyle": "italic" }
    },
    {
      "name": "Markdown link",
      "scope": "markup.underline.link, string.other.link",
      "settings": { "foreground": "#3A4E6E" }
    },
    {
      "name": "Markdown code",
      "scope": "markup.inline.raw, markup.fenced_code.block",
      "settings": { "foreground": "#456B28" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": "#96600A",
    "method": "#96600A",
    "type": "#3A4E6E",
    "class": "#3A4E6E",
    "interface": "#3A4E6E",
    "enum": "#3A4E6E",
    "enumMember": "#3A4E6E",
    "variable.readonly": "#3A4E6E",
    "parameter": "#4D4035",
    "property": "#4D4035",
    "string": "#456B28",
    "keyword": "#8B2252",
    "number": "#96600A",
    "comment": { "foreground": "#928578", "fontStyle": "italic" }
  }
}
